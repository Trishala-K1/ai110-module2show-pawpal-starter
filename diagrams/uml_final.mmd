classDiagram
    class Task {
        +str description
        +str time
        +int duration_minutes
        +str frequency
        +str priority
        +bool completed
        +date due_date
        +mark_complete() None
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list tasks
        +add_task(task) None
        +get_tasks() list
        +task_count() int
    }

    class Owner {
        +str name
        +list pets
        +add_pet(pet) None
        +get_all_tasks() list
    }

    class Scheduler {
        +Owner owner
        +get_todays_tasks() list
        +sort_by_time(task_pairs) list
        +filter_by_pet(pet_name, task_pairs) list
        +filter_by_status(completed, task_pairs) list
        +mark_task_complete(pet, task) Task
        +detect_conflicts(task_pairs) list
        +get_schedule() list
        +format_schedule() str
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "1" Owner : manages
    Task ..> Task : next_occurrence creates
